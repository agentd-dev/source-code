{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "issue-triage classification",
  "type": "object",
  "required": ["area", "severity", "summary"],
  "additionalProperties": false,
  "properties": {
    "area": {
      "type": "string",
      "enum": ["bug", "feature", "docs", "question"]
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    }
  }
}
