{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "document classification",
  "type": "object",
  "required": ["label", "confidence"],
  "properties": {
    "label": { "enum": ["invoice", "contract", "spam"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
