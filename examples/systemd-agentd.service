# agentd as a long-lived reactive daemon under systemd.
# Install at /etc/systemd/system/agentd-triage.service, then:
#   systemctl daemon-reload && systemctl enable --now agentd-triage
[Unit]
Description=agentd ticket triage (reactive)
After=network.target

[Service]
Type=simple
Environment=AGENTD_INTELLIGENCE=unix:/run/intelligence.sock
# Secrets via EnvironmentFile (mode 0600), never on the command line or a config
# file (RFC 0011 §3.2). The file sets AGENTD_INTELLIGENCE_TOKEN=...
EnvironmentFile=/etc/agentd/triage.env
ExecStart=/usr/local/bin/agentd \
  --mode reactive \
  --instruction-file /etc/agentd/triage.txt \
  --model my-model \
  --mcp tickets=mcp-server-tickets \
  --subscribe tickets://queue/inbound \
  --drain-timeout 25s \
  --health-file /run/agentd/health

# systemd's analogue of terminationGracePeriodSeconds — MUST exceed
# --drain-timeout (25s) or systemd SIGKILLs mid-drain.
TimeoutStopSec=30
KillSignal=SIGTERM
Restart=on-failure
RestartSec=5
RuntimeDirectory=agentd

[Install]
WantedBy=multi-user.target
