{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "churn-risk scoring",
  "type": "object",
  "required": ["risk_band", "top_accounts", "summary"],
  "additionalProperties": false,
  "properties": {
    "risk_band": { "type": "string", "enum": ["calm", "elevated", "urgent"] },
    "top_accounts": { "type": "string", "description": "comma-separated account names, highest risk first" },
    "summary": { "type": "string", "minLength": 1 }
  }
}
