{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "contract clause extraction",
  "type": "object",
  "required": ["liability_cap", "auto_renewal", "governing_law", "risk"],
  "additionalProperties": false,
  "properties": {
    "liability_cap": { "type": "string" },
    "auto_renewal": { "type": "boolean" },
    "governing_law": { "type": "string" },
    "risk": {
      "type": "string",
      "enum": ["standard", "review"],
      "description": "review when any clause deviates from the playbook"
    }
  }
}
