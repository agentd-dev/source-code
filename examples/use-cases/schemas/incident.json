{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "incident hypothesis + plan",
  "type": "object",
  "required": ["hypothesis", "blast_radius", "proposed_mitigation"],
  "additionalProperties": false,
  "properties": {
    "hypothesis": { "type": "string", "minLength": 1 },
    "blast_radius": { "type": "string", "enum": ["single-host", "service", "customer-facing"] },
    "proposed_mitigation": {
      "type": "string",
      "description": "plain-language description of the one pre-approved mitigation to run, or 'none'"
    }
  }
}
