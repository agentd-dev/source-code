{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "order risk score",
  "type": "object",
  "required": ["band", "signals"],
  "additionalProperties": false,
  "properties": {
    "band": { "type": "string", "enum": ["low", "medium", "high"] },
    "signals": { "type": "string", "description": "plain-language list of the signals behind the band" }
  }
}
