{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "structured application screen",
  "type": "object",
  "required": ["score", "strengths", "gaps", "recommendation"],
  "additionalProperties": false,
  "properties": {
    "score": { "type": "integer", "minimum": 1, "maximum": 5 },
    "strengths": { "type": "string", "minLength": 1 },
    "gaps": { "type": "string", "minLength": 1 },
    "recommendation": {
      "type": "string",
      "enum": ["advance", "decline"],
      "description": "advance to interview, or decline (declines always require human sign-off)"
    }
  }
}
