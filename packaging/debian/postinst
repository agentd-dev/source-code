#!/bin/sh
# cargo-deb `maintainer-scripts` — runs on install / upgrade.
# Creates /etc/agentd/ (empty) for any operator config (e.g. an instruction
# file referenced via --instruction-file in /etc/default/agentd).

set -e

install -d -m 0755 /etc/agentd

if [ -x /usr/bin/systemctl ]; then
    /usr/bin/systemctl daemon-reload || true
fi

#DEBHELPER#

exit 0
