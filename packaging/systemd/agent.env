# /etc/default/agent — environment for agent.service.
#
# agent is instruction-driven: it needs an INSTRUCTION (the unit of work) and an
# intelligence endpoint. Set those here, plus any mode/flag tuning in AGENT_ARGS
# (expanded on the ExecStart line). Full reference: `agent --help` and
# docs/configuration.md.

# The intelligence endpoint + model (required). Reach a hosted model over
# unix: to a TLS-terminating sidecar (the default TLS-free build), or build with
# the `tls` feature to dial https:// directly.
AGENT_INTELLIGENCE=unix:/run/agent/intel.sock
AGENT_MODEL=claude-sonnet-4-6

# The intelligence credential (redacted in logs). Prefer a systemd credential or
# a drop-in over a world-readable env file in production.
#AGENT_INTELLIGENCE_TOKEN=

# The instruction (the unit of work). For a long instruction, point at a file
# with `--instruction-file` in AGENT_ARGS instead.
#INSTRUCTION=Summarize new items and act on them.

AGENT_LOG_LEVEL=info

# Mode + flags. Default is a one-shot `once` run; for a long-lived reactive
# daemon use `--mode reactive --subscribe <uri>`. Add `--metrics-addr
# 127.0.0.1:9090` (local scrape) or `:9090` (all IPv4 interfaces) to serve
# /healthz+/readyz+/metrics (needs the metrics build).
AGENT_ARGS=--mode once --drain-timeout 25s
