# /etc/default/agentd — environment for agentd.service.
#
# AGENTD_ARGS is expanded on the ExecStart command line. Edit this
# file to change binding, timeout, feature flags, or logging without
# touching the unit file; systemctl daemon-reload is NOT required.
#
# Full flag reference:
#   agentd --help
#   docs/configuration.md

AGENTD_ARGS=--config /etc/agentd/workflow.toml --bind 127.0.0.1:8080 --drain-timeout-secs 30

# Uncomment to override logging. CLI flags take precedence, so
# keep AGENTD_ARGS free of --log-* when you set these.
#AGENTD_LOG=info
#AGENTD_LOG_FORMAT=json
#AGENTD_LOG_TARGET=stderr
