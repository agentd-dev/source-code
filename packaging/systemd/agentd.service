[Unit]
Description=Bounded workflow runtime (agentd)
Documentation=https://github.com/agentd-dev/source-code/tree/main/docs
After=network-online.target
Wants=network-online.target

[Service]
Type=exec
EnvironmentFile=-/etc/default/agentd
ExecStart=/usr/bin/agentd $AGENTD_ARGS
Restart=on-failure
RestartSec=5s

# Graceful shutdown. TimeoutStopSec MUST exceed the workflow's
# --drain-timeout-secs (default 30) or systemd will SIGKILL
# mid-drain and in-flight requests will error.
KillSignal=SIGTERM
TimeoutStopSec=60s

# --- Hardening ---------------------------------------------------
# Dynamic UID/GID: no persistent user needed. Pair with
# StateDirectory / LogsDirectory below for write-access paths.
DynamicUser=yes

# StateDirectory → /var/lib/agentd ; LogsDirectory → /var/log/agentd.
# Both are created with the correct dynamic-user perms on first
# start and kept across restarts.
StateDirectory=agentd
StateDirectoryMode=0750
LogsDirectory=agentd
LogsDirectoryMode=0750

# Filesystem namespace: the process can only write to /var/lib/agentd,
# /var/log/agentd, and /tmp (PrivateTmp).
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=yes
ReadOnlyPaths=/etc/agentd

# Kernel + namespace isolation.
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes
RestrictNamespaces=yes
RestrictRealtime=yes
LockPersonality=yes

# No executable pages except what ld.so needs at startup.
MemoryDenyWriteExecute=yes

# Syscall allowlist. @system-service is the standard set.
SystemCallFilter=@system-service
SystemCallErrorNumber=EPERM
SystemCallArchitectures=native

# Networking: UNIX for intel socket; INET / INET6 for HTTP. No
# raw sockets, no netlink.
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6

# Drop all capabilities. The runtime never needs any.
CapabilityBoundingSet=
AmbientCapabilities=
NoNewPrivileges=yes

# If a workflow needs to bind to port <1024, enable via drop-in:
#   systemctl edit agentd
# and add: CapabilityBoundingSet=CAP_NET_BIND_SERVICE
# + AmbientCapabilities=CAP_NET_BIND_SERVICE under [Service].

[Install]
WantedBy=multi-user.target
